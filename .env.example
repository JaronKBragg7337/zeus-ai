# Docker Compose defaults. Copy this file to .env only when you need overrides.
# Ollama stays on the host by design; do not put credentials in this file.
ZEUSAI_OLLAMA_BASE_URL=http://host.docker.internal:11434
ZEUSAI_BACKEND_PORT=8000
ZEUSAI_FRONTEND_PORT=3000
# ZEUSAI_WORKSPACE=.
# ZEUSAI_ENABLE_SHELL=0
